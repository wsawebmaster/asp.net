@model ProjetoMVC.Models.Produto
@{
    ViewData["Title"] = "Editar";

}

<h2>Editar Produto</h2>

<form asp-action="Edit" method="post">
    <input type="hidden" name="Id" value="@Model.Id" />

    <div class="form-group">
        <label for="Nome">Nome</label>
        <input type="text" class="form-control" id="Nome" name="Nome" value="@Model.Nome" required />
    </div>
    <div class="form-group">
        <label for="Preco">Preço</label>
        <input type="number" class="form-control" id="Preco" name="Preco" value="@Model.Preco" step="0.01" required />
    </div>

    <button type="submit" class="btn btn-success">Salvar</button>

    <a asp-action="Index" class="btn btn-primary">Voltar</a>
</form>